// todo osrs and 2004 seems to have different level req messages.
// note: we have correct level up messages for 2004.
// https://youtu.be/RHwRNK4ZuOM?t=411
// todo need more info on 2004 messages. all of these are osrs messages.

// AP: Archipelago progressive-gear-tier gate (2004Scape-AP-Logic
// docs/checks-and-unlocks.md, unlock family A). ap_unlock_count() returns 99 when
// data/config/ap-unlocks.json does not exist, so every ~ap_gear_locked() call below
// returns false and this whole file behaves exactly like vanilla outside an AP run.
// Gated AFTER the existing stat-level check on every base label (never before it -
// the vanilla level message should still fire first for someone who hasn't even
// trained the stat yet), so the quest-gated wrapper labels below (which @goto into
// a base label) automatically inherit both their quest check AND this gate for free.
[proc,ap_gear_locked](string $unlock, string $family_name, int $level)(boolean)
def_int $tier = 0;
if ($level >= 60) {
    $tier = 7;
} else if ($level >= 45) {
    $tier = 6;
} else if ($level >= 40) {
    $tier = 5;
} else if ($level >= 30) {
    $tier = 4;
} else if ($level >= 20) {
    $tier = 3;
} else if ($level >= 10) {
    $tier = 2;
} else if ($level >= 5) {
    $tier = 1;
}
if ($tier = 0) {
    // tier 1 (level 1) gear is always free - sphere 0 always has combat.
    return(false);
}
if (ap_unlock_count($unlock) < $tier) {
    mes("Your Archipelago progression hasn't unlocked this equipment tier yet.");
    mes("(needs Progressive <$family_name> <tostring($tier)>)");
    return(true);
}
return(false);

[label,levelrequire_attack](int $level, int $slot)
if (stat_base(attack) < $level) {
    mes("You are not a high enough level to use this item.");
    mes("You need to have an attack level of <tostring($level)>.");
    return;
}
if (~ap_gear_locked("progressive_melee", "Melee", $level) = true) {
    return;
}
~equip($slot);

[label,levelrequire_defence](int $level, int $slot)
if (stat_base(defence) < $level) {
    mes("You are not a high enough level to use this item.");
    mes("You need to have a defence level of <tostring($level)>.");
    return;
}
if (~ap_gear_locked("progressive_armour", "Armour", $level) = true) {
    return;
}
~equip($slot);

