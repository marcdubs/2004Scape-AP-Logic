[label,levelrequire_viking_quest_helm](int $level, int $slot)
if (%viking < ^viking_complete) {
    mes("Only Fremenniks are worthy of wearing this helm.");
    mes("You need to complete The Fremennik Trials first."); // todo confirm for 2004
    return;
}
@levelrequire_defence($level, $slot);

[proc,levelrequire_dragon_slayer_quest]()(boolean)
if (%dragonquest < ^dragon_complete) {
    mes("You have not earned the right to wear this yet.");
    mes("You need to complete the Dragon Slayer quest first."); // todo confirm for 2004
    return(false);
}
return(true);

