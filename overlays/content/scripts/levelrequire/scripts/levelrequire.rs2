[label,levelrequire_iban_staff](int $slot)
// https://youtu.be/FKFdDdH5rlE?si=rTj214wpX9RKHiMy&t=188
if (stat_base(magic) < 50) {
    mes("You are not a high enough level to use this item,");
    mes("You need to have a Magic level of 50.");
    return;
}
if (stat_base(attack) < 50) {
    mes("You are not a high enough level to use this item.");
    mes("You need to have an Attack level of 50.");
    return;
}
if (~ap_gear_locked("progressive_magic", "Magic", 50) = true) {
    return;
}
~equip($slot);

[label,levelrequire_attack_and_strength](int $attack_level, int $strength_level, int $slot)
if (stat_base(attack) < $attack_level | stat_base(strength) < $strength_level) {
    mes("You are not a high enough level to use this item.");
    mes("You need to have an attack level of <tostring($attack_level)> and a strength level of <tostring($strength_level)>.");
    return;
}
if (~ap_gear_locked("progressive_melee", "Melee", $attack_level) = true) {
    return;
}
~equip($slot);

[label,levelrequire_regicide_quest_attack_strength](int $attack, int $strength, int $slot)
if (~levelrequire_regicide_quest = false) {
    return;
}
@levelrequire_attack_and_strength($attack, $strength, $slot);
