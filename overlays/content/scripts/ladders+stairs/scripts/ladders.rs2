// Ship ladder (climb up)
[oploc1,shipladder_angled]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
switch_int (loc_angle) {
	case 0 : p_teleport(movecoord(coord, 0, 1, 2));
	case 1 : p_teleport(movecoord(coord, 2, 1, 0));
	case 2 : p_teleport(movecoord(coord, 0, 1, -2));
	case 3 : p_teleport(movecoord(coord, -2, 1, 0));
}

// Ship ladder (climb down)
[oploc1,shipladder_top_angled]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
switch_int (loc_angle) {
	case 0 : p_teleport(movecoord(coord, 0, -1, 2));
	case 1 : p_teleport(movecoord(coord, 2, -1, 0));
	case 2 : p_teleport(movecoord(coord, 0, -1, -2));
	case 3 : p_teleport(movecoord(coord, -2, -1, 0));
}

// Climb Up
[oploc1,ship_ladder]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, 1, 0), true);

// Climb Down
[oploc1,ship_laddertop]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, -1, 0), false);

// Climb-down op
[oploc1,wizards_tower_laddertop]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
def_coord $coord = loc_coord();

// wizard tower level 0
if ($coord = 0_48_49_32_26) {
    ~climb_ladder(0_48_149_32_40, false);
} else {
    mes("unhandled ladder <~coord_tostring($coord)>");
}

[oploc1,laddertop]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
switch_coord (loc_coord) {
    case 2_47_54_17_57 : ~climb_ladder(1_47_54_17_58, false); // black knights fortress ladder
    case default : ~climb_ladder(movecoord(coord(), 0, -1, 0), false);   
}

[oploc1,ladder]
// AP: the dwarf guard tower ladder (0_40_53_10_49) is quest-gated inside
// ladder_to_dwarf_remains (quest_mcannon/scripts/locs/mcannon_ladders.rs2) - the
// override consult for that one coord happens THERE, after the %mcannon check, not
// here, so a shuffled destination can never bypass the gate. Every other placement of
// this category keeps the normal top-of-handler consult.
if (loc_coord ! 0_40_53_10_49) {
    def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
    if ($ap_dest ! null) {
        @ap_entrance_go($ap_dest);
    }
}
p_arrivedelay;
switch_coord (loc_coord) {
    case 0_40_53_10_49 : @ladder_to_dwarf_remains; // Ladder to Dwarf Guard Tower
    case default : ~climb_ladder(movecoord(coord(), 0, 1, 0), true);
}

[oploc1,laddermiddle]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
@ladder_options(movecoord(coord(), 0, 1, 0), movecoord(coord(), 0, -1, 0));

