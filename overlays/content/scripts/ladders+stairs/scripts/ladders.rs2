}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, 1, 0), true);

[oploc1,ladder_cellar]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, 0, 6400), false);

[oploc1,ladder_from_cellar] // mining guild ladder
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
def_coord $coord = loc_coord;
p_arrivedelay;
if(loc_coord = 0_50_149_22_52) { // Zanaris ladder (entrance room)
    ~climb_ladder(0_50_49_1_33, true);
    return;
}
~climb_ladder(movecoord(coord(), 0, 0, -6400), true);

[oploc1,ladder_from_cellar_directional] 
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, 0, -6400), true);

[oploc1,ladder_cellar_inside_down]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, 0, 6400), false);

[oploc1,wildymirrorladdertop1]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
def_coord $coord = loc_coord();
p_arrivedelay;
switch_coord ($coord) {
    case 0_40_50_1_22 : ~climb_ladder(0_40_150_1_21, false); // Monk's Friend hidden ladder
    case 0_47_60_9_9 : p_teleport(0_47_160_61_15); // kdb entrance (yes its a p_teleport)
    case default : mes("unhandled ladder <~coord_tostring($coord)>");
}

// Climb-up op
[oploc1,wizards_tower_ladder]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
def_coord $coord = loc_coord();

// wizard tower cellar
if ($coord = 0_48_149_31_40) {
    ~climb_ladder(0_48_49_33_26, true);
} else {
    mes("unhandled ladder <~coord_tostring($coord)>");
}

[oploc1,phoenixladder]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(0_50_52_44_54, true);

[oploc1,grandtree_laddermiddle]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
def_int $option = ~p_choice2_header("Climb Up.", 1, "Climb Down.", 2, "Climb up or down the ladder?");
if_close;
anim(human_reachforladder, 0);
p_delay(1);
if ($option = 1) {
    ~grandtree_spawn_charlie;
    p_telejump(movecoord(coord(), 0, 1, 0));
} else if ($option = 2) {
    p_telejump(movecoord(coord(), 0, -1, 0));
}

[oploc2,grandtree_laddermiddle]
def_coord $ap_dest = ap_entrance_override(loc_coord, 2);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
~grandtree_spawn_charlie; // before the arrivedelay
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, 1, 0), true);

[oploc3,grandtree_laddermiddle]
def_coord $ap_dest = ap_entrance_override(loc_coord, 3);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, -1, 0), true);

[oploc1,laddertop_norim]
def_coord $ap_dest = ap_entrance_override(loc_coord, 1);
if ($ap_dest ! null) {
    @ap_entrance_go($ap_dest);
}
p_arrivedelay;
~climb_ladder(movecoord(coord(), 0, -1, 0), false);

[proc,climb_ladder](coord $coord, boolean $up)
if ($up = true) {
    anim(human_reachforladder, 0);
} else {
    anim(human_pickupfloor, 0);
}
p_delay(0);
p_telejump($coord);

[label,ladder_options](coord $up, coord $down)
def_int $option = ~p_choice2_header("Climb Up.", 1, "Climb Down.", 2, "Climb up or down the ladder?");
if_close;
anim(human_reachforladder, 0);
p_delay(1);
def_coord $ap_up = ap_entrance_override(loc_coord, 2);
def_coord $ap_down = ap_entrance_override(loc_coord, 3);
if ($option = 1) {
    if ($ap_up ! null) {
        p_telejump($ap_up);
        return;
    }
    p_telejump($up);
} else if ($option = 2) {
    if ($ap_down ! null) {
        p_telejump($ap_down);
        return;
    }
    p_telejump($down);
}

[label,unhandled_ladder](coord $loccoord)
mes("Unhandled ladder: <~coord_tostring($loccoord)>");
