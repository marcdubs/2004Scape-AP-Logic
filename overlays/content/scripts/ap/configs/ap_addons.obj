// AP addon reward items (problems.txt 2026-07-17, docs/checks-and-unlocks.md
// "Addon items"). Each is gated by an ap-options.json toggle at REWARD-ROLL
// time (ap_try_addon_reward in ap_rewards.rs2) - an already-delivered item
// keeps working if its option is later disabled (fail-open usage, consistent
// with every other AP toggle). Visual assets are borrowed from vanilla objs:
// casket (bank box - user request), trail sextant (tree compass), staff orb
// recolors (foci), sealed scroll (npc teleport). Pack ids auto-append on
// build.

[ap_bank_box]
name=Bank Box
desc=A magical box connected to every bank in RuneScape.
weight=5kg
model=inv_casket
2dxof=3
2dyof=-6
2dzoom=1410
2dyan=1592
2dxan=164
cost=50
iop1=Bank
members=yes
tradeable=no

