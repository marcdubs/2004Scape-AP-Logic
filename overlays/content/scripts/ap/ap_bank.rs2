// Archipelago testing bank kit. Additive only - never inv_clear(bank) - so it's safe
// to run on a character with an existing bank; it just tops up tools/materials for
// exercising every non-combat skill in one pass (including the gathering and
// processing randomizers). Dispatched via the ungated ::ap<name> test-command
// infrastructure (see docs/goals-and-checks.md), so it works even with
// node.production: true set.
//
// Bank capacity is 240 distinct slots (interface_bank/configs/bank.constant) and
// `stackall=yes` there means quantity never costs extra slots - only distinct items
// do. This kit is ~140 distinct items, leaving headroom for whatever's already
// banked.

// ::apbank - top up the caller's bank with tools + materials for every gathering and
// processing skill (mining/fishing/woodcutting, cooking/smithing/crafting/fletching,
// plus herblore basics).
[debugproc,ap_bank]
if (p_finduid(uid) = false) {
    return;
}

// --- tools ---
inv_add(bank, bronze_pickaxe, 1);
inv_add(bank, iron_pickaxe, 1);
inv_add(bank, steel_pickaxe, 1);
inv_add(bank, mithril_pickaxe, 1);
inv_add(bank, adamant_pickaxe, 1);
inv_add(bank, rune_pickaxe, 1);

inv_add(bank, bronze_axe, 1);
inv_add(bank, iron_axe, 1);
inv_add(bank, steel_axe, 1);
inv_add(bank, mithril_axe, 1);
inv_add(bank, adamant_axe, 1);
inv_add(bank, rune_axe, 1);

inv_add(bank, fishing_rod, 1);
inv_add(bank, fly_fishing_rod, 1);
inv_add(bank, harpoon, 1);
inv_add(bank, lobster_pot, 1);
inv_add(bank, net, 1);
inv_add(bank, big_net, 1);
inv_add(bank, fishing_bait, 1000);

inv_add(bank, hammer, 1);
inv_add(bank, chisel, 1);
inv_add(bank, needle, 1);
inv_add(bank, thread, 100);
inv_add(bank, knife, 1);
inv_add(bank, tinderbox, 1);
inv_add(bank, pestle_and_mortar, 1);

// --- mining / smithing ---
inv_add(bank, clay, 1000);
inv_add(bank, copper_ore, 1000);
inv_add(bank, tin_ore, 1000);
inv_add(bank, iron_ore, 1000);
inv_add(bank, silver_ore, 1000);
inv_add(bank, coal, 1000);
inv_add(bank, gold_ore, 1000);
inv_add(bank, mithril_ore, 1000);
inv_add(bank, adamantite_ore, 1000);
inv_add(bank, runite_ore, 1000);

inv_add(bank, bronze_bar, 1000);
inv_add(bank, iron_bar, 1000);
inv_add(bank, steel_bar, 1000);
inv_add(bank, silver_bar, 1000);
inv_add(bank, gold_bar, 1000);
inv_add(bank, mithril_bar, 1000);
inv_add(bank, adamantite_bar, 1000);
inv_add(bank, runite_bar, 1000);

// --- woodcutting / fletching / firemaking ---
inv_add(bank, logs, 1000);
inv_add(bank, oak_logs, 1000);
inv_add(bank, willow_logs, 1000);
inv_add(bank, maple_logs, 1000);
inv_add(bank, yew_logs, 1000);
inv_add(bank, magic_logs, 1000);
inv_add(bank, achey_tree_logs, 1000);

inv_add(bank, feather, 1000);
inv_add(bank, arrow_shaft, 1000);
inv_add(bank, headless_arrow, 1000);
inv_add(bank, bow_string, 1000);

inv_add(bank, bronze_arrowheads, 1000);
inv_add(bank, iron_arrowheads, 1000);
inv_add(bank, steel_arrowheads, 1000);
inv_add(bank, mithril_arrowheads, 1000);
inv_add(bank, adamant_arrowheads, 1000);
inv_add(bank, rune_arrowheads, 1000);

inv_add(bank, bronze_dart_tip, 1000);
inv_add(bank, iron_dart_tip, 1000);
inv_add(bank, steel_dart_tip, 1000);
inv_add(bank, mithril_dart_tip, 1000);
inv_add(bank, adamant_dart_tip, 1000);
inv_add(bank, rune_dart_tip, 1000);

inv_add(bank, bolt, 1000);
inv_add(bank, opal, 1000);
inv_add(bank, smalloysterpearls, 1000);
inv_add(bank, bigoysterpearls, 1000);
inv_add(bank, opal_bolttips, 1000);
