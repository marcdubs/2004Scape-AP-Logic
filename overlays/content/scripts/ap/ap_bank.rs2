// --- herblore ---
inv_add(bank, vial_empty, 200);
inv_add(bank, vial_water, 200);
inv_add(bank, unidentified_guam, 200);
inv_add(bank, unidentified_marentill, 200);
inv_add(bank, unidentified_tarromin, 200);
inv_add(bank, unidentified_harralander, 200);
inv_add(bank, unidentified_ranarr, 200);
inv_add(bank, unidentified_irit, 200);
